---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface GitHubData {
  stars: number;
  forks: number;
}

const allEntries = await getCollection('projects');

// Group entries by project slug (first path segment)
const projectMap = new Map<string, CollectionEntry<'projects'>[]>();
for (const entry of allEntries) {
  const slug = entry.id.split('/')[0];
  if (!projectMap.has(slug)) projectMap.set(slug, []);
  projectMap.get(slug)!.push(entry);
}

// Find the index entry for each project
const projects: CollectionEntry<'projects'>[] = [];
for (const [slug, entries] of projectMap) {
  const indexEntry = entries.find(e => e.id === `${slug}/index.md`);
  if (indexEntry) {
    projects.push(indexEntry);
  }
}

// Separate featured and normal
const featured = projects.filter(p => p.data.featured);
const normal = projects.filter(p => !p.data.featured);

if (featured.length > 6) {
  throw new Error(
    `Too many featured projects: ${featured.length}. Maximum allowed is 6. ` +
    `Please un-feature some projects in their frontmatter.`
  );
}

// Sort featured by slug (alphabetical)
featured.sort((a, b) => a.id.localeCompare(b.id));

// Sort normal alphabetically by slug
normal.sort((a, b) => a.id.localeCompare(b.id));

// Fetch GitHub metrics for projects that want them
const githubCache = new Map<string, GitHubData>();
for (const project of projects) {
  if (project.data.github && project.data.showGitHubMetrics && !githubCache.has(project.data.github)) {
    try {
      const res = await fetch(`https://api.github.com/repos/${project.data.github}`, {
        headers: { 'Accept': 'application/vnd.github.v3+json' },
      });
      if (res.ok) {
        const json = await res.json();
        githubCache.set(project.data.github, {
          stars: json.stargazers_count ?? 0,
          forks: json.forks_count ?? 0,
        });
      } else {
        githubCache.set(project.data.github, { stars: 0, forks: 0 });
      }
    } catch {
      githubCache.set(project.data.github, { stars: 0, forks: 0 });
    }
  }
}

function getProjectUrl(entry: CollectionEntry<'projects'>): string {
  const slug = entry.id.split('/')[0];
  return `/projects/${slug}`;
}
---

<BaseLayout title="Projects" description="Selected projects and experiments.">
  <aside class="sidebar">
    <div class="sidebar-top">
      <nav class="sidebar-nav">
        <a href="/">/home</a>
        <a href="/blogs">/blogs</a>
        <a href="/projects">/projects</a>
        <a href="/about">/about</a>
        <a href="/resume">/resume</a>
      </nav>
    </div>
    <div class="sidebar-bottom">
      <a href="https://github.com/ButterHost69" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sidebar-icon">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
      <a href="https://linkedin.com/in/palash-spatel" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sidebar-icon">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
      </a>
    </div>
  </aside>

  <main class="main-content">
    <h1 class="page-title">/projects</h1>

    {featured.length > 0 && (
      <section class="featured-section">
        <h2 class="section-label">featured</h2>
        <div class="featured-grid">
          {featured.map(project => {
            const slug = project.id.split('/')[0];
            const ghData = project.data.github && project.data.showGitHubMetrics
              ? githubCache.get(project.data.github)
              : undefined;
            return (
              <a href={getProjectUrl(project)} class="featured-card">
                {project.data.thumbnail && (
                  <div class="card-image-wrapper">
                    <img src={project.data.thumbnail} alt={`${project.data.title} preview`} class="card-image" />
                  </div>
                )}
                <div class="card-body">
                  <div class="card-header">
                    <span class="card-title">{project.data.title}</span>
                    {ghData && (
                      <span class="card-stars">
                        <svg viewBox="0 0 24 24" fill="currentColor" class="star-icon"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {ghData.stars.toLocaleString()}
                      </span>
                    )}
                  </div>
                  <p class="card-desc">{project.data.cardDescription || project.data.description || ''}</p>
                  <div class="card-footer">
                    {project.data.tags.slice(0, 3).map(tag => (
                      <span class="card-tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {normal.length > 0 && (
      <section class="list-section">
        <h2 class="section-label">all projects</h2>
        <div class="project-list">
          {normal.map(project => (
            <a href={getProjectUrl(project)} class="list-item">
              <span class="list-name">{project.data.title}</span>
              <span class="list-desc">{project.data.cardDescription || project.data.description || ''}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Iosevka+Charon:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap');

  :root {
    --burnt-bg:    #140a05;
    --text:        #f5f0e0;
    --text-muted:  #a89878;
    --accent:      #e0a820;
    --accent-soft: #c89420;
    --glass:       rgba(20, 10, 5, 0.65);
    --glass-hover: rgba(20, 10, 5, 0.82);
    --glass-border:rgba(224, 168, 32, 0.10);
    --highlight:   inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  :global(body) {
    background-color: var(--burnt-bg);
    background-image: url('https://github.com/ButterHost69/ButterHost69.github.io/blob/main/images/wallpapers/my-neighbor-totoro-sunflowers.png?raw=true');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
    color: var(--text);
  }

  :global(body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(20, 10, 5, 0.72);
    z-index: -1;
    pointer-events: none;
  }

  /* ── Sidebar ───────────────────────────────────────── */
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 280px;
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
    border-right: 1px solid var(--glass-border);
    padding: 2.5rem 1.8rem;
    overflow-y: auto;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 0 0 transparent, var(--highlight);
  }

  .sidebar-top { display: flex; flex-direction: column; gap: 1.4rem; }

  .sidebar-bottom {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(168, 152, 120, 0.15);
  }

  .sidebar-bottom a {
    color: var(--text-muted);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex;
    align-items: center;
    padding: 0.5rem;
    border-radius: 50%;
  }

  .sidebar-bottom a:hover {
    color: var(--accent);
    background: var(--glass-hover);
    transform: translateY(-3px);
  }

  .sidebar-icon { width: 1.4rem; height: 1.4rem; }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sidebar-nav a {
    font-family: "Iosevka Charon", monospace;
    font-weight: 500;
    font-style: italic;
    font-size: 1rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.55rem 1.8rem;
    margin: 0 -1.8rem;
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .sidebar-nav a:hover {
    color: var(--text);
    background: var(--glass-hover);
    box-shadow: 0 2px 12px rgba(224, 168, 32, 0.12);
  }

  /* ── Main content ──────────────────────────────────── */
  .main-content {
    margin-left: 280px;
    padding: 2.5rem 3.5rem;
    min-height: 100vh;
    box-sizing: border-box;
  }

  .page-title {
    font-family: 'Iosevka Charon', sans-serif;
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 2.5rem;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.5);
  }

  .section-label {
    font-family: "Iosevka Charon", monospace;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: lowercase;
    margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }

  /* ── Featured grid ─────────────────────────────────── */
  .featured-section { margin-bottom: 3.5rem; }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
    border: 1px solid var(--glass-border);
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    transition: all 0.25s ease;
  }

  .featured-card:hover {
    border-color: rgba(224, 168, 32, 0.25);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
    transform: translateY(-2px);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.3);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-title {
    font-family: "Iosevka Charon", monospace;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--accent);
  }

  .card-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: "Iosevka Charon", monospace;
    font-size: 0.78rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .star-icon {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--accent);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding-top: 0.4rem;
  }

  .card-tag {
    font-family: "Iosevka Charon", monospace;
    font-size: 0.7rem;
    color: var(--accent-soft);
    background: rgba(224, 168, 32, 0.1);
    padding: 0.15em 0.5em;
  }

  /* ── List section ──────────────────────────────────── */
  .list-section { margin-bottom: 2rem; }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .list-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0.8rem;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s ease;
    border-radius: 0;
  }

  .list-item:hover {
    background: rgba(20, 10, 5, 0.35);
  }

  .list-item:hover .list-name {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-soft);
  }

  .list-name {
    font-family: "Iosevka Charon", monospace;
    font-weight: 500;
    font-size: 0.95rem;
    flex-shrink: 0;
    min-width: 180px;
  }

  .list-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .sidebar { display: none; }
    .main-content { margin-left: 0; padding: 1.5rem; }
    .featured-grid { grid-template-columns: 1fr; }
    .list-item { flex-direction: column; gap: 0.2rem; }
    .list-desc { white-space: normal; }
  }
</style>