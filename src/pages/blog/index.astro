---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog" description="Writing on ML, security, and building things.">
  <section style="padding: 5rem 0 6rem;">
    <div class="container prose">
      <h1 style="margin-bottom: 0.5rem;">Writing</h1>
      <p style="color: var(--muted); margin-bottom: 4rem;">
        Notes on machine learning, security research, and things I'm building.
      </p>

      {posts.length === 0 && (
        <p style="color: var(--muted); font-style: italic;">No posts yet — check back soon.</p>
      )}

      <div style="display: flex; flex-direction: column; gap: 0;">
        {posts.map((post, i) => (
          <a href={`/blog/${post.slug}`} style={`display: block; text-decoration: none; color: inherit; padding: 2rem 0; border-bottom: 1px solid var(--border);`}>
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; flex-wrap: wrap;">
              <h2 style="font-size: 1.25rem; font-family: var(--font-display); color: var(--ink);">{post.data.title}</h2>
              <time style="font-size: 0.8rem; color: var(--muted); white-space: nowrap; flex-shrink: 0;" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </time>
            </div>
            <p style="color: var(--muted); font-size: 0.92rem; margin-top: 0.4rem; margin-bottom: 0.8rem;">{post.data.description}</p>
            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {post.data.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
