---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me" description="About me">
  <aside class="drawer">
    <div class="drawer-content">
      <div class="section">
        <a href="/projects" class="section-title">All Projects</a>
        <a href="/blogs" class="section-title">All Blogs</a>
      </div>

      <div class="separator"></div>

      <div class="section">
        <span class="section-title">Featured Projects</span>
        <div class="tree">
          <div class="tree-item">adapTrunc</div>
          <div class="tree-item">├─ CSM proxy metric</div>
          <div class="tree-item">├─ Layer truncation</div>
          <div class="tree-item">└─ Text classification</div>
          <div class="tree-item">Cybersecurity Lab</div>
          <div class="tree-item">├─ Burp Suite</div>
          <div class="tree-item">├─ IDOR patterns</div>
          <div class="tree-item">└─ Privilege escalation</div>
          <div class="tree-item">This site</div>
          <div class="tree-item">└─ Astro portfolio</div>
        </div>
      </div>

      <div class="section">
        <span class="section-title">Featured Blogs</span>
        <div class="tree">
          <div class="tree-item">hello-world</div>
          <div class="tree-item">└─ Welcome post</div>
        </div>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <h1>Palash S Patel</h1>
    <div class="about-section">
      <p>
        CS/engineering student with interests in machine learning,
        web security, and building things that feel good to use.
      </p>
      <p>
        Currently working on <span class="highlight">adapTrunc</span>, exploring whether class
        separability can serve as a proxy for optimal BERT layer truncation
        — aiming for faster inference without fine-tuning every layer.
      </p>
      <p>
        Outside of research, I spend time on security labs, building
        small web tools, and occasionally writing about what I'm learning.
      </p>
      <div class="skills">
        <span class="project-tag ml">Machine Learning</span>
        <span class="project-tag security">Web Security</span>
        <span class="project-tag web">Web Dev</span>
      </div>
    </div>
    <div class="decorative-line"></div>
    <div class="contact-section">
      <a href="#" class="contact-link">Twitter</a>
      <a href="#" class="contact-link">GitHub</a>
      <a href="#" class="contact-link">Email</a>
    </div>
  </main>
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
    background: var(--ivory);
  }

  .top-bar {
    position: fixed;
    top: var(--space-md);
    right: var(--space-lg);
    display: flex;
    gap: var(--space-md);
    z-index: 100;
  }

  .top-link {
    text-transform: lowercase;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .top-link:hover {
    color: var(--violet);
  }

  .main-content {
    margin: 0 auto;
    padding: var(--space-lg) var(--space-xl);
    max-width: 1200px;
    min-height: 100vh;
    box-sizing: border-box;
    width: 100%;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: calc(var(--space-lg) * 0.7);
    color: var(--ink);
    font-family: 'Iosevka Charon', sans-serif;
    font-weight: 700;
  }

  .about-section h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-md);
    margin-top: calc(var(--space-xl) * 0.7);
    color: var(--dark);
    border-bottom: 2px solid var(--border);
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  .about-section p {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.4em;
    color: var(--ink);
  }

  .highlight {
    background: var(--accent);
    color: var(--ink);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  .drawer {
    position: fixed;
    left: 0;
    top: 0;
    width: 280px;
    height: 100vh;
    background: var(--violet);
    backdrop-filter: blur(10px);
    padding: var(--space-lg) var(--space-md);
    overflow-y: auto;
    border-right: 3px solid var(--violet);
  }

  .drawer-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .section-title {
    font-size: 1.3rem;
    text-transform: lowercase;
    letter-spacing: 0.08em;
    color: var(--ivory);
    padding: 0.3rem 0;
    font-weight: 600;
    display: block;
    text-decoration: underline;
    text-decoration-color: var(--link);
    text-underline-offset: 4px;
  }

  .section-title:hover {
    color: var(--link);
  }

  .separator {
    height: 2px;
    background: var(--border);
    margin: var(--space-sm) 0;
    border-radius: 1px;
  }

  .tree {
    font-family: monospace;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--ink);
  }

  .tree-item {
    padding-left: 0.5rem;
    transition: color 0.2s;
    cursor: pointer;
  }

  .tree-item:hover {
    color: var(--violet);
  }

  .project-tag {
    display: inline-block;
    background: var(--muted);
    color: var(--ivory);
    font-size: 0.7rem;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    margin-right: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .project-tag.security {
    background: var(--violet);
  }

  .project-tag.ml {
    background: var(--dark);
  }

  .project-tag.web {
    background: var(--border);
    color: var(--ink);
  }

  .decorative-line {
    height: 4px;
    background: linear-gradient(90deg, var(--violet), var(--accent), var(--border), var(--dark));
    margin: var(--space-xl) 0;
    border-radius: 2px;
  }

  .contact-section {
    display: flex;
    gap: var(--space-md);
  }

  .contact-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .contact-link:hover {
    color: var(--violet);
  }

  @media (max-width: 1100px) {
  .drawer {
    display: none;
  }
}
</style>