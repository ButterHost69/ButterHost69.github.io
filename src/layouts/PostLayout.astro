---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<BaseLayout title={title} description={description}>
  <article style="padding: 5rem 0 6rem;">
    <div class="container prose">
      <header style="margin-bottom: 3rem; text-align: center;">
        <div style="margin-bottom: 1rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <h1>{title}</h1>
        <p style="color: var(--muted); margin-top: 1rem; font-size: 0.9rem;">
          {formatted}
        </p>
      </header>

      <hr style="border: none; border-top: 1px solid var(--border); margin-bottom: 3rem;" />

      <div class="prose-content">
        <slot />
      </div>

      <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border);">
        <a href="/blog" style="font-size: 0.9rem; color: var(--muted); text-decoration: none;">
          ← Back to blog
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
