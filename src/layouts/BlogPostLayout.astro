---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <aside class="sidebar">
    <div class="sidebar-top">
      <nav class="sidebar-nav">
        <a href="/">/home</a>
        <a href="/blogs">/blogs</a>
        <a href="/projects">/projects</a>
        <a href="/about">/about</a>
        <a href="/resume">/resume</a>
      </nav>
    </div>
    <div class="sidebar-bottom">
      <a href="https://github.com/ButterHost69" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sidebar-icon">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
      <a href="https://linkedin.com/in/palash-spatel" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sidebar-icon">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
      </a>
    </div>
  </aside>

  <main class="main-content">
    <article class="post-container">
      <header class="post-header">
        {tags.length > 0 && (
          <div class="tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
        <h1 class="post-title">{title}</h1>
        <time class="post-date" datetime={pubDate.toISOString()}>{formatted}</time>
      </header>

      <hr class="divider" />

      <div class="post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <a href="/blogs" class="back-link">← Back to blogs</a>
      </footer>
    </article>
  </main>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Iosevka+Charon:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap');

  :root {
    --burnt-bg:         #140a05;
    --text:             #f5f0e0;
    --text-muted:       #a89878;
    --accent:           #e0a820;
    --accent-soft:      #c89420;
    --glass:            rgba(20, 10, 5, 0.65);
    --glass-hover:      rgba(20, 10, 5, 0.82);
    --glass-border:     rgba(224, 168, 32, 0.10);
    --highlight:        inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  :global(body) {
    background-color: var(--burnt-bg);
    background-image: url('https://github.com/ButterHost69/ButterHost69.github.io/blob/main/images/wallpapers/my-neighbor-totoro-sunflowers.png?raw=true');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
    color: var(--text);
  }

  :global(body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(20, 10, 5, 0.72);
    z-index: -1;
    pointer-events: none;
  }

  /* ── Sidebar ───────────────────────────────────────── */
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 280px;
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
    border-right: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 2.5rem 1.8rem;
    overflow-y: auto;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 0 0 transparent, var(--highlight);
  }

  .sidebar-top {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .sidebar-bottom {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(168, 152, 120, 0.15);
  }

  .sidebar-bottom a {
    color: var(--text-muted);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex;
    align-items: center;
    padding: 0.5rem;
    border-radius: 50%;
  }

  .sidebar-bottom a:hover {
    color: var(--accent);
    background: var(--glass-hover);
    transform: translateY(-3px);
  }

  .sidebar-icon {
    width: 1.4rem;
    height: 1.4rem;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sidebar-nav a {
    font-family: "Iosevka Charon", monospace;
    font-weight: 500;
    font-style: italic;
    font-size: 1rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.55rem 1.8rem;
    margin: 0 -1.8rem;
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .sidebar-nav a:hover {
    color: var(--text);
    background: var(--glass-hover);
    box-shadow: 0 2px 12px rgba(224, 168, 32, 0.12);
  }

  /* ── Main content ──────────────────────────────────── */
  .main-content {
    margin-left: 280px;
    padding: 1.5rem;
    min-height: 100vh;
    box-sizing: border-box;
  }

  .post-container {
    width: 100%;
    min-height: calc(100vh - 3rem);
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
    border: 1px solid var(--glass-border);
    padding: 3rem;
    border-radius: 0;
    box-sizing: border-box;
  }

  .post-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    display: inline-block;
    background: rgba(224, 168, 32, 0.15);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.2em 0.75em;
    border-radius: 999px;
    font-family: "Iosevka Charon", monospace;
  }

  .post-title {
    font-family: 'Iosevka Charon', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: "Iosevka Charon", monospace;
  }

  .divider {
    border: none;
    border-top: 1px solid rgba(168, 152, 120, 0.18);
    margin: 2rem 0;
  }

  /* ── Markdown prose styles ─────────────────────────── */
  .post-content :global(h2) {
    font-family: 'Iosevka Charon', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    font-family: 'Iosevka Charon', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.8rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.4em;
    line-height: 1.75;
    color: var(--text);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.4em;
  }

  .post-content :global(li) {
    margin-bottom: 0.4em;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.6em 1.2em;
    margin: 2em 0;
    color: var(--text-muted);
    font-style: italic;
    background: rgba(20, 10, 5, 0.3);
  }

  .post-content :global(code) {
    background: rgba(224, 168, 32, 0.12);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
    font-family: "Iosevka Charon", monospace;
  }

  .post-content :global(pre) {
    background: rgba(0, 0, 0, 0.5);
    padding: 1.4em;
    border-radius: 0;
    overflow-x: auto;
    margin: 2em 0;
    border: 1px solid var(--glass-border);
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text);
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    color: var(--text);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(168, 152, 120, 0.18);
    margin: 2.5em 0;
  }

  .post-content :global(strong) {
    color: var(--accent-soft);
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 0;
    margin: 2em 0;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(168, 152, 120, 0.18);
  }

  .back-link {
    font-family: "Iosevka Charon", monospace;
    font-weight: 500;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .main-content {
      margin-left: 0;
      padding: 1.5rem;
      padding-bottom: 3rem;
    }

    .post-container {
      padding: 1.5rem;
    }
  }
</style>
